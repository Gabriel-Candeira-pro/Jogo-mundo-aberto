{
  "name": "Gayme Dev",
  "forwardPorts": [8080, 3000],
  "portsAttributes": {
    "8080": {
      "label": "Frontend (webpack dev server)",
      "onAutoForward": "openPreview",
      "visibility": "public"
    },
    "3000": {
      "label": "Backend (API server)",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "postCreateCommand": "npm run install:all"
}
