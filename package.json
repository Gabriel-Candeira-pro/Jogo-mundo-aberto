{
  "name": "gaymer",
  "version": "2.0.0",
  "description": "Jogo Phaser responsivo - Mobile e Desktop com Backend",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --mode development --open",
    "dev:ngrok": "node scripts/ngrok.js",
    "dev:server": "nodemon server/server.js",
    "build": "webpack --mode production",
    "start": "http-server . -c-1 -o",
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "full": "concurrently \"npm run server\" \"npm run dev\""
  },
  "keywords": ["phaser", "game", "mobile", "desktop", "multiplayer", "backend"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "html-webpack-plugin": "^5.5.3",
    "http-server": "^14.1.1",
    "ngrok": "^4.3.3",
    "nodemon": "^3.0.0",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "phaser": "^3.55.2",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3"
  }
}
