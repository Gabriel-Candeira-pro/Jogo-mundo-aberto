{
  "name": "gayme-monorepo",
  "version": "2.0.0",
  "description": "Jogo Multiplayer - Web, Mobile e Backend Compartilhado",
  "private": true,
  "workspaces": [
    "web",
    "mobile"
  ],
  "scripts": {
    "prefull": "node scripts/ensure-ports-free.js",
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "web:dev": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web",
    "mobile:start": "cd mobile && npm run start",
    "mobile:android": "cd mobile && npm run android",
    "mobile:ios": "cd mobile && npm run ios",
    "build:apk": "cd mobile && npm run build:apk",
    "build:android": "cd mobile && npm run build:android",
    "full": "concurrently \"npm run server\" \"npm run web:dev\"",
    "install:all": "npm install && npm install --workspace=web && npm install --workspace=mobile"
  },
  "keywords": ["phaser", "game", "mobile", "desktop", "multiplayer", "backend", "react-native"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "ngrok": "^4.3.3",
    "nodemon": "^3.0.0",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3"
  }
}
